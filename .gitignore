# ── Environment ──────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

